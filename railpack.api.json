{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "npm ci",
        "npx prisma generate"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        "npm run build --workspace @hyrox/shared",
        "npm run build --workspace @hyrox/api"
      ]
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "build"
      }
    ],
    "startCommand": "sh -c 'npx prisma db push && npm run start --workspace @hyrox/api'"
  }
}
